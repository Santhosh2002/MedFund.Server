{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=medfund;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "MedFund",
    "Audience": "MedFund.Frontend",
    "SigningKey": "replace-with-a-local-secret-of-at-least-32-characters",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 14
  },
  "Database": {
    "ApplyMigrationsOnStartup": true,
    "SeedDevelopmentDataOnStartup": true
  },
  "Storage": {
    "LocalRoot": "storage/documents"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*"
}
